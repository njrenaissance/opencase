# =============================================================================
# OpenCase — Test Environment
# =============================================================================
# Fake secrets for automated testing only.
# Do NOT use these values in production.
# This file is committed to source control intentionally — the values here
# are meaningless outside a test context.
#
# Used by two consumers:
#   1. conftest.py  — loaded before app imports; provides settings for unit
#                     and integration tests that run on the host (localhost:5432)
#   2. pytest-docker — passed as --env-file to docker compose for integration
#                      test stack setup (POSTGRES_* vars, auth secrets, etc.)
# =============================================================================

# =============================================================================
# Secrets
# =============================================================================
OPENCASE_AUTH_SECRET_KEY="test-secret-key-for-automated-testing-only"
NEXTAUTH_SECRET="test-nextauth-secret-for-integration-tests"

# =============================================================================
# PostgreSQL — container init (docker compose reads these)
# =============================================================================
# Matches POSTGRES_USER / POSTGRES_PASSWORD in infrastructure/docker-compose.yml
POSTGRES_USER="opencase"
POSTGRES_PASSWORD="test-only-password"
POSTGRES_DB="opencase"
POSTGRES_PORT="5432"

# =============================================================================
# Database — host-side connection (used by conftest.py / test_db_schema.py)
# =============================================================================
# Uses localhost because these tests run on the host, not inside Docker.
# The integration compose override (docker-compose.integration.yml) sets a
# separate OPENCASE_DB_URL inside the fastapi container using the Docker
# service hostname (postgres:5432).
OPENCASE_DB_URL="postgresql+asyncpg://opencase:test-only-password@localhost:5432/opencase_test"

# =============================================================================
# API Server
# =============================================================================
OPENCASE_API_HOST="0.0.0.0"
OPENCASE_API_PORT="8000"

# =============================================================================
# S3 Storage (MinIO)
# =============================================================================
OPENCASE_S3_ENDPOINT="minio:9000"
OPENCASE_S3_ACCESS_KEY="opencase"
OPENCASE_S3_SECRET_KEY="changeme"
OPENCASE_S3_BUCKET="opencase"
OPENCASE_S3_USE_SSL="false"
OPENCASE_S3_REGION="us-east-1"

# =============================================================================
# Ollama
# =============================================================================
OLLAMA_LLM_MODEL="llama3:8b"

# =============================================================================
# Qdrant
# =============================================================================
OPENCASE_QDRANT_HOST="localhost"
OPENCASE_QDRANT_PORT="6333"
OPENCASE_QDRANT_GRPC_PORT="6334"
OPENCASE_QDRANT_COLLECTION="opencase_test"
OPENCASE_QDRANT_PREFER_GRPC="false"
OPENCASE_QDRANT_USE_SSL="false"

# =============================================================================
# Embedding
# =============================================================================
OPENCASE_EMBEDDING_PROVIDER="ollama"
OPENCASE_EMBEDDING_MODEL="nomic-embed-text"
OPENCASE_EMBEDDING_BASE_URL="http://localhost:11434"
OPENCASE_EMBEDDING_DIMENSIONS="768"
OPENCASE_EMBEDDING_BATCH_SIZE="100"
OPENCASE_EMBEDDING_REQUEST_TIMEOUT="120"

# =============================================================================
# Auth sub-settings (defaults — no need to override in tests)
# =============================================================================
OPENCASE_AUTH_ALGORITHM="HS256"
OPENCASE_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES="15"
OPENCASE_AUTH_REFRESH_TOKEN_EXPIRE_DAYS="7"
OPENCASE_AUTH_TOTP_ISSUER="OpenCase"
OPENCASE_AUTH_TOTP_DIGEST="sha1"
OPENCASE_AUTH_TOTP_WINDOW="1"
OPENCASE_AUTH_BCRYPT_ROUNDS="4"
OPENCASE_AUTH_LOGIN_LOCKOUT_ATTEMPTS="5"
OPENCASE_AUTH_LOGIN_LOCKOUT_MINUTES="15"

# =============================================================================
# Application settings
# =============================================================================
DEPLOYMENT_MODE="airgapped"
OPENCASE_DEBUG="false"
OPENCASE_LOG_LEVEL="INFO"
OPENCASE_LOG_OUTPUT="stdout"
OPENCASE_OTEL_ENABLED="false"
OPENCASE_OTEL_EXPORTER="console"
OPENCASE_OTEL_ENDPOINT="http://localhost:4318"
OPENCASE_OTEL_SERVICE_NAME="opencase-api"
OPENCASE_OTEL_SAMPLE_RATE="1.0"

# =============================================================================
# Admin Bootstrap (REQUIRED — first admin user created on initial startup)
# =============================================================================
OPENCASE_ADMIN_EMAIL="admin@test.corafirm.com"
OPENCASE_ADMIN_PASSWORD="Hq105loxzTCYcMp2AyUGF+Ldxyg3zz8Q"
OPENCASE_ADMIN_FIRST_NAME="Test"
OPENCASE_ADMIN_LAST_NAME="Admin"
OPENCASE_ADMIN_FIRM_NAME="Test Firm"

# =============================================================================
# Redis
# =============================================================================
OPENCASE_REDIS_HOST="localhost"
OPENCASE_REDIS_PORT="6379"
OPENCASE_REDIS_DB="0"
OPENCASE_REDIS_SSL="false"
OPENCASE_REDIS_POOL_SIZE="10"

# =============================================================================
# Celery
# =============================================================================
# broker_url is intentionally omitted — the Settings model validator derives
# it from OPENCASE_REDIS_* fields above, so changing the Redis host/port/db
# automatically updates the broker address.
#
# Result backend — Celery task results stored in opencase_tasks_test DB
OPENCASE_CELERY_RESULT_BACKEND="db+postgresql://opencase:test-only-password@localhost:5432/opencase_tasks_test"
OPENCASE_CELERY_TASK_SERIALIZER="json"
OPENCASE_CELERY_ACCEPT_CONTENT='["json"]'
OPENCASE_CELERY_TIMEZONE="UTC"
OPENCASE_CELERY_WORKER_CONCURRENCY="2"
OPENCASE_CELERY_TASK_SOFT_TIME_LIMIT="300"
OPENCASE_CELERY_TASK_HARD_TIME_LIMIT="600"
OPENCASE_CELERY_TASK_ACKS_LATE="true"
OPENCASE_CELERY_WORKER_PREFETCH_MULTIPLIER="1"

# =============================================================================
# Flower
# =============================================================================
OPENCASE_FLOWER_PORT="5555"
OPENCASE_FLOWER_URL_PREFIX="/flower"
