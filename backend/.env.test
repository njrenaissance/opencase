# =============================================================================
# Gideon — Test Environment
# =============================================================================
# Fake secrets for automated testing only.
# Do NOT use these values in production.
# This file is committed to source control intentionally — the values here
# are meaningless outside a test context.
#
# Used by two consumers:
#   1. conftest.py  — loaded before app imports; provides settings for unit
#                     and integration tests that run on the host (localhost:5432)
#   2. pytest-docker — passed as --env-file to docker compose for integration
#                      test stack setup (POSTGRES_* vars, auth secrets, etc.)
# =============================================================================

# =============================================================================
# Secrets
# =============================================================================
GIDEON_AUTH_SECRET_KEY="test-secret-key-for-automated-testing-only"
NEXTAUTH_SECRET="test-nextauth-secret-for-integration-tests"

# =============================================================================
# PostgreSQL — container init (docker compose reads these)
# =============================================================================
# Matches POSTGRES_USER / POSTGRES_PASSWORD in infrastructure/docker-compose.yml
POSTGRES_USER="gideon"
POSTGRES_PASSWORD="test-only-password"
POSTGRES_DB="gideon"
POSTGRES_PORT="5432"

# =============================================================================
# Database — host-side connection (used by conftest.py / test_db_schema.py)
# =============================================================================
# Uses localhost because these tests run on the host, not inside Docker.
# The integration compose override (docker-compose.integration.yml) sets a
# separate GIDEON_DB_URL inside the fastapi container using the Docker
# service hostname (postgres:5432).
GIDEON_DB_URL="postgresql+asyncpg://gideon:test-only-password@localhost:5432/gideon_test"

# =============================================================================
# API Server
# =============================================================================
GIDEON_API_HOST="0.0.0.0"
GIDEON_API_PORT="8000"

# =============================================================================
# S3 Storage (MinIO)
# =============================================================================
GIDEON_S3_ENDPOINT="minio:9000"
GIDEON_S3_ACCESS_KEY="gideon"
GIDEON_S3_SECRET_KEY="changeme"
GIDEON_S3_BUCKET="gideon"
GIDEON_S3_USE_SSL="false"
GIDEON_S3_REGION="us-east-1"

# =============================================================================
# Chatbot / LLM inference
# =============================================================================
GIDEON_CHATBOT_MODEL="llama3"
GIDEON_CHATBOT_BASE_URL="http://localhost:11434"
GIDEON_CHATBOT_TEMPERATURE="0.1"
GIDEON_CHATBOT_MAX_TOKENS="4096"
GIDEON_CHATBOT_RETRIEVAL_CHUNK_COUNT="5"

# =============================================================================
# Qdrant
# =============================================================================
GIDEON_QDRANT_HOST="localhost"
GIDEON_QDRANT_PORT="6333"
GIDEON_QDRANT_GRPC_PORT="6334"
GIDEON_QDRANT_COLLECTION="gideon_test"
GIDEON_QDRANT_PREFER_GRPC="false"
GIDEON_QDRANT_USE_SSL="false"

# =============================================================================
# Embedding
# =============================================================================
GIDEON_EMBEDDING_PROVIDER="ollama"
GIDEON_EMBEDDING_MODEL="nomic-embed-text"
GIDEON_EMBEDDING_BASE_URL="http://localhost:11434"
GIDEON_EMBEDDING_DIMENSIONS="768"
GIDEON_EMBEDDING_BATCH_SIZE="100"
GIDEON_EMBEDDING_REQUEST_TIMEOUT="120"

# =============================================================================
# Auth sub-settings (defaults — no need to override in tests)
# =============================================================================
GIDEON_AUTH_ALGORITHM="HS256"
GIDEON_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES="15"
GIDEON_AUTH_REFRESH_TOKEN_EXPIRE_DAYS="7"
GIDEON_AUTH_TOTP_ISSUER="Gideon"
GIDEON_AUTH_TOTP_DIGEST="sha1"
GIDEON_AUTH_TOTP_WINDOW="1"
GIDEON_AUTH_BCRYPT_ROUNDS="4"
GIDEON_AUTH_LOGIN_LOCKOUT_ATTEMPTS="5"
GIDEON_AUTH_LOGIN_LOCKOUT_MINUTES="15"

# =============================================================================
# Application settings
# =============================================================================
DEPLOYMENT_MODE="airgapped"
GIDEON_DEBUG="false"
GIDEON_LOG_LEVEL="INFO"
GIDEON_LOG_OUTPUT="stdout"
GIDEON_OTEL_ENABLED="false"
GIDEON_OTEL_EXPORTER="console"
GIDEON_OTEL_ENDPOINT="http://localhost:4318"
GIDEON_OTEL_SERVICE_NAME="gideon-api"
GIDEON_OTEL_SAMPLE_RATE="1.0"

# =============================================================================
# Admin Bootstrap (REQUIRED — first admin user created on initial startup)
# =============================================================================
GIDEON_ADMIN_EMAIL="admin@test.corafirm.com"
GIDEON_ADMIN_PASSWORD="Hq105loxzTCYcMp2AyUGF+Ldxyg3zz8Q"
GIDEON_ADMIN_FIRST_NAME="Test"
GIDEON_ADMIN_LAST_NAME="Admin"
GIDEON_ADMIN_FIRM_NAME="Test Firm"

# =============================================================================
# Redis
# =============================================================================
GIDEON_REDIS_HOST="localhost"
GIDEON_REDIS_PORT="6379"
GIDEON_REDIS_DB="0"
GIDEON_REDIS_SSL="false"
GIDEON_REDIS_POOL_SIZE="10"

# =============================================================================
# Celery
# =============================================================================
# broker_url is intentionally omitted — the Settings model validator derives
# it from GIDEON_REDIS_* fields above, so changing the Redis host/port/db
# automatically updates the broker address.
#
# Result backend — Celery task results stored in gideon_tasks_test DB
GIDEON_CELERY_RESULT_BACKEND="db+postgresql://gideon:test-only-password@localhost:5432/gideon_tasks_test"
GIDEON_CELERY_TASK_SERIALIZER="json"
GIDEON_CELERY_ACCEPT_CONTENT='["json"]'
GIDEON_CELERY_TIMEZONE="UTC"
GIDEON_CELERY_WORKER_CONCURRENCY="2"
GIDEON_CELERY_TASK_SOFT_TIME_LIMIT="300"
GIDEON_CELERY_TASK_HARD_TIME_LIMIT="600"
GIDEON_CELERY_TASK_ACKS_LATE="true"
GIDEON_CELERY_WORKER_PREFETCH_MULTIPLIER="1"

# =============================================================================
# Flower
# =============================================================================
GIDEON_FLOWER_PORT="5555"
GIDEON_FLOWER_URL_PREFIX="/flower"
