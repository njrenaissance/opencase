# =============================================================================
# OpenCase — Environment Configuration
# =============================================================================
# Copy this file and fill in required values:
#
#   cp .env.example .env
#   # Edit .env — replace every CHANGE_ME value
#
# Start services:
#
#   docker compose -f infrastructure/docker-compose.yml --env-file .env up -d
#
# =============================================================================

# =============================================================================
# Deployment Mode
# =============================================================================
# "airgapped"  — no external network calls (default, most secure)
# "internet"   — enables scheduled cloud ingestion (OneDrive / SharePoint)
# Docker Compose passes this into containers as DEPLOYMENT_MODE.
# Pydantic-settings reads OPENCASE_DEPLOYMENT_MODE (OPENCASE_ prefix).
# For local dev without Docker, use OPENCASE_DEPLOYMENT_MODE instead.
DEPLOYMENT_MODE="airgapped"

# =============================================================================
# Secrets (REQUIRED — services will not start without these)
# =============================================================================
# Next.js session signing key (generate: openssl rand -base64 32)
NEXTAUTH_SECRET="CHANGE_ME_nextauth_secret"

# FastAPI JWT signing key (generate: openssl rand -base64 32)
FASTAPI_SECRET_KEY="CHANGE_ME_fastapi_secret"

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER="opencase"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="opencase"

# =============================================================================
# MinIO (S3-Compatible Object Storage)
# =============================================================================
MINIO_ACCESS_KEY="opencase"
MINIO_SECRET_KEY="changeme"

# =============================================================================
# Ollama (Local LLM + Embeddings)
# =============================================================================
# LLM used for chat / Q&A inference
OLLAMA_LLM_MODEL="llama3:8b"

# Embedding model used for vector search
OLLAMA_EMBED_MODEL="nomic-embed-text"

# =============================================================================
# Application Settings (OPENCASE_ prefix — read by pydantic-settings)
# =============================================================================
OPENCASE_DEBUG="false"
OPENCASE_LOG_LEVEL="INFO"
# Log destination: "stdout" or "stderr"
OPENCASE_LOG_OUTPUT="stdout"

# =============================================================================
# OpenTelemetry (disabled by default)
# =============================================================================
OPENCASE_OTEL_ENABLED="false"
# Exporter: "console" (local dev) or "otlp" (collector)
OPENCASE_OTEL_EXPORTER="console"
OPENCASE_OTEL_ENDPOINT="http://localhost:4318"
OPENCASE_OTEL_SERVICE_NAME="opencase-api"
# Trace sampling rate (0.0–1.0)
OPENCASE_OTEL_SAMPLE_RATE="1.0"

# =============================================================================
# Cloud Ingestion — Azure (internet mode only)
# =============================================================================
# Required only when DEPLOYMENT_MODE="internet"
# Register an app in Azure AD: https://portal.azure.com
# AZURE_CLIENT_ID=""
# AZURE_CLIENT_SECRET=""
# AZURE_TENANT_ID=""

# =============================================================================
# Internal service addresses (managed by Docker Compose — do NOT set here)
# =============================================================================
# The following are hardcoded in docker-compose.yml for the Docker network:
#   DATABASE_URL, REDIS_URL, QDRANT_HOST, QDRANT_PORT, QDRANT_COLLECTION,
#   OLLAMA_HOST, MINIO_ENDPOINT, MINIO_BUCKET, MINIO_USE_SSL,
#   NEXT_PUBLIC_API_URL, NEXTAUTH_URL, FASTAPI_UPSTREAM

