# =============================================================================
# Gideon — Environment Configuration
# =============================================================================
# Copy this file and fill in required values:
#
#   cp .env.example .env
#   # Edit .env — replace every CHANGE_ME value
#
# Start services:
#
#   docker compose -f infrastructure/docker-compose.yml --env-file .env up -d
#
# =============================================================================

# =============================================================================
# Deployment Mode
# =============================================================================
# "airgapped"  — no external network calls (default, most secure)
# "internet"   — enables scheduled cloud ingestion (SharePoint)
# Docker Compose passes this into containers as DEPLOYMENT_MODE.
# Pydantic-settings reads GIDEON_DEPLOYMENT_MODE (GIDEON_ prefix).
# For local dev without Docker, use GIDEON_DEPLOYMENT_MODE instead.
DEPLOYMENT_MODE="airgapped"

# =============================================================================
# Secrets (REQUIRED — services will not start without these)
# =============================================================================
# Next.js session signing key (generate: openssl rand -base64 32)
NEXTAUTH_SECRET="CHANGE_ME_nextauth_secret"

# FastAPI JWT signing key (generate: openssl rand -base64 32)
# Read by pydantic-settings as GIDEON_AUTH_SECRET_KEY
GIDEON_AUTH_SECRET_KEY="CHANGE_ME_fastapi_secret"

# =============================================================================
# Admin Bootstrap (REQUIRED — first admin user created on initial startup)
# =============================================================================
GIDEON_ADMIN_EMAIL="CHANGE_ME_admin@example.com"
GIDEON_ADMIN_PASSWORD="CHANGE_ME_admin_password"
GIDEON_ADMIN_FIRST_NAME="Admin"
GIDEON_ADMIN_LAST_NAME="User"
GIDEON_ADMIN_FIRM_NAME="Default Firm"

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER="gideon"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="gideon"
# Host port the container binds to (change if 5432 is already in use)
POSTGRES_PORT="5432"

# =============================================================================
# S3 Storage — GIDEON_S3_ prefix (read by pydantic-settings)
# =============================================================================
# MinIO API endpoint (Docker service name:port inside compose network)
GIDEON_S3_ENDPOINT="minio:9000"
# MinIO root user (also used as access key)
GIDEON_S3_ACCESS_KEY="gideon"
# MinIO root password (also used as secret key)
GIDEON_S3_SECRET_KEY="changeme"
# Default bucket for document storage
GIDEON_S3_BUCKET="gideon"
# Use TLS/SSL for MinIO connections (false for internal Docker traffic)
GIDEON_S3_USE_SSL="false"
# AWS region (MinIO default, required by boto3)
GIDEON_S3_REGION="us-east-1"

# =============================================================================
# Ollama (Local LLM)
# =============================================================================
# LLM used for chat / Q&A inference (future LLM settings class)
OLLAMA_LLM_MODEL="llama3:8b"
# NOTE: Embedding model config has moved to GIDEON_EMBEDDING_* section below.

# =============================================================================
# Authentication (GIDEON_AUTH_ prefix — read by pydantic-settings)
# =============================================================================
# JWT signing key — set above as GIDEON_AUTH_SECRET_KEY (required)
# Algorithm for JWT signing
GIDEON_AUTH_ALGORITHM="HS256"
# Access token lifetime in minutes
GIDEON_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES="15"
# Refresh token lifetime in days
GIDEON_AUTH_REFRESH_TOKEN_EXPIRE_DAYS="7"
# TOTP issuer name shown in authenticator apps
GIDEON_AUTH_TOTP_ISSUER="Gideon"
# TOTP hash algorithm (sha1, sha256, sha512) — sha1 is the RFC 6238 default
GIDEON_AUTH_TOTP_DIGEST="sha1"
# TOTP time-step tolerance (1 = ±30 seconds)
GIDEON_AUTH_TOTP_WINDOW="1"
# bcrypt work factor (increase to slow down brute force attacks)
GIDEON_AUTH_BCRYPT_ROUNDS="12"
# Failed login attempts before lockout
GIDEON_AUTH_LOGIN_LOCKOUT_ATTEMPTS="5"
# Lockout duration in minutes
GIDEON_AUTH_LOGIN_LOCKOUT_MINUTES="15"

# =============================================================================
# Database (GIDEON_DB_ prefix — read by pydantic-settings)
# =============================================================================
# Full SQLAlchemy async DSN (required)
# Managed by Docker Compose — do NOT change unless running outside Docker
GIDEON_DB_URL="postgresql+asyncpg://gideon:changeme@postgres:5432/gideon"
GIDEON_DB_POOL_SIZE="10"
GIDEON_DB_MAX_OVERFLOW="20"
GIDEON_DB_POOL_PRE_PING="true"
# Set to true only for debugging — logs all SQL queries
GIDEON_DB_ECHO="false"

# =============================================================================
# API Server (GIDEON_API_ prefix — read by pydantic-settings)
# =============================================================================
# Bind address inside the container (0.0.0.0 = all interfaces)
GIDEON_API_HOST="0.0.0.0"
# Port uvicorn listens on inside the container
GIDEON_API_PORT="8000"

# =============================================================================
# Application Settings (GIDEON_ prefix — read by pydantic-settings)
# =============================================================================
GIDEON_DEBUG="false"
GIDEON_LOG_LEVEL="INFO"
# Log destination: "stdout" or "stderr"
GIDEON_LOG_OUTPUT="stdout"

# =============================================================================
# OpenTelemetry (disabled by default)
# =============================================================================
GIDEON_OTEL_ENABLED="false"
# Exporter: "console" (local dev) or "otlp" (collector)
GIDEON_OTEL_EXPORTER="console"
GIDEON_OTEL_ENDPOINT="http://grafana:4318"
GIDEON_OTEL_SERVICE_NAME="gideon-api"
# Trace sampling rate (0.0–1.0)
GIDEON_OTEL_SAMPLE_RATE="1.0"

# =============================================================================
# Redis (GIDEON_REDIS_ prefix — read by pydantic-settings)
# =============================================================================
# Redis host (Docker service name inside compose network)
GIDEON_REDIS_HOST="redis"
# Redis port
GIDEON_REDIS_PORT="6379"
# Redis database number (0–15)
GIDEON_REDIS_DB="0"
# Redis password (optional — leave blank for no authentication)
# GIDEON_REDIS_PASSWORD=""
# Enable TLS/SSL for Redis connections
GIDEON_REDIS_SSL="false"
# Connection pool size
GIDEON_REDIS_POOL_SIZE="10"

# =============================================================================
# Celery (GIDEON_CELERY_ prefix — read by pydantic-settings)
# =============================================================================
# Broker URL — must match Redis settings above (host, port, db, password)
# Update this if you override GIDEON_REDIS_HOST, PORT, DB, or PASSWORD.
GIDEON_CELERY_BROKER_URL="redis://redis:6379/0"
# Result backend — Celery task results stored in gideon_tasks DB
# Uses synchronous PostgreSQL driver (psycopg2) — NOT asyncpg.
GIDEON_CELERY_RESULT_BACKEND="db+postgresql://gideon:changeme@postgres:5432/gideon_tasks"
# Task serialization format
GIDEON_CELERY_TASK_SERIALIZER="json"
# Accepted content types (JSON array)
GIDEON_CELERY_ACCEPT_CONTENT='["json"]'
# Timezone for scheduled tasks
GIDEON_CELERY_TIMEZONE="UTC"
# Number of concurrent worker processes
GIDEON_CELERY_WORKER_CONCURRENCY="2"
# Soft time limit per task in seconds (5 min)
GIDEON_CELERY_TASK_SOFT_TIME_LIMIT="300"
# Hard time limit per task in seconds (10 min)
GIDEON_CELERY_TASK_HARD_TIME_LIMIT="600"
# Acknowledge tasks after completion (safer for crash recovery)
GIDEON_CELERY_TASK_ACKS_LATE="true"
# Tasks prefetched per worker (1 = fair scheduling)
GIDEON_CELERY_WORKER_PREFETCH_MULTIPLIER="1"

# =============================================================================
# Flower (GIDEON_FLOWER_ prefix — read by pydantic-settings)
# =============================================================================
# Flower web UI port
GIDEON_FLOWER_PORT="5555"
# Basic auth credentials (format: user:password, optional)
# GIDEON_FLOWER_BASIC_AUTH=""
# URL prefix for reverse proxy
GIDEON_FLOWER_URL_PREFIX="/flower"

# =============================================================================
# Extraction Pipeline (GIDEON_EXTRACTION_ prefix — read by pydantic-settings)
# =============================================================================
# Apache Tika server endpoint (Docker service name inside compose network).
# For local dev without Docker, change to http://localhost:9998.
GIDEON_EXTRACTION_TIKA_URL="http://tika:9998"
# Enable Tesseract OCR for scanned/image documents
GIDEON_EXTRACTION_OCR_ENABLED="true"
# Tesseract language packs (comma-separated, e.g. "eng,fra,deu")
GIDEON_EXTRACTION_OCR_LANGUAGES="eng"
# HTTP timeout for Tika extraction requests (seconds)
GIDEON_EXTRACTION_REQUEST_TIMEOUT="120"
# Maximum file size sent to Tika for extraction (bytes, default 100 MB)
GIDEON_EXTRACTION_MAX_FILE_SIZE_BYTES="104857600"

# =============================================================================
# Ingestion (GIDEON_INGESTION_ prefix — read by pydantic-settings)
# =============================================================================
# Path to a flat file listing allowed MIME types and file extensions
# (one entry per line, # comments allowed). When unset, built-in defaults
# are used (PDF, Word, Excel, images, etc.). See docs/SETTINGS.md for
# format details and the full default list.
# GIDEON_INGESTION_ALLOWED_TYPES_FILE="/etc/gideon/allowed_types.txt"

# =============================================================================
# Chunking (GIDEON_CHUNKING_ prefix — read by pydantic-settings)
# =============================================================================
# Text splitting strategy ("recursive" is the only option currently)
GIDEON_CHUNKING_STRATEGY="recursive"
# Maximum characters per chunk
GIDEON_CHUNKING_CHUNK_SIZE="1000"
# Overlap between adjacent chunks (must be less than chunk_size)
GIDEON_CHUNKING_CHUNK_OVERLAP="200"
# Separator priority for recursive splitting (JSON array)
# GIDEON_CHUNKING_SEPARATORS='["\n\n", "\n", ". ", " ", ""]'

# =============================================================================
# Embedding (GIDEON_EMBEDDING_ prefix — read by pydantic-settings)
# =============================================================================
# Embedding provider ("ollama" only — airgapped deployment)
GIDEON_EMBEDDING_PROVIDER="ollama"
# Embedding model name (must be pulled in Ollama)
GIDEON_EMBEDDING_MODEL="nomic-embed-text"
# Ollama API base URL (Docker service name inside compose network)
GIDEON_EMBEDDING_BASE_URL="http://ollama:11434"
# Output vector dimensions (must match the model — 768 for nomic-embed-text)
GIDEON_EMBEDDING_DIMENSIONS="768"
# Number of chunks per embedding batch request
GIDEON_EMBEDDING_BATCH_SIZE="100"
# HTTP timeout for embedding requests (seconds)
GIDEON_EMBEDDING_REQUEST_TIMEOUT="120"

# =============================================================================
# Qdrant Vector Store (GIDEON_QDRANT_ prefix — read by pydantic-settings)
# =============================================================================
# Qdrant server hostname (Docker service name inside compose network)
GIDEON_QDRANT_HOST="qdrant"
# Qdrant REST API port
GIDEON_QDRANT_PORT="6333"
# Qdrant gRPC port
GIDEON_QDRANT_GRPC_PORT="6334"
# Collection name for document vectors
GIDEON_QDRANT_COLLECTION="gideon"
# Prefer gRPC transport (faster for bulk operations)
GIDEON_QDRANT_PREFER_GRPC="true"
# Use HTTPS for Qdrant connections (enable when TLS is configured)
GIDEON_QDRANT_USE_SSL="false"
# API key (optional — only needed when Qdrant auth is enabled)
# GIDEON_QDRANT_API_KEY=""

# =============================================================================
# Cloud Ingestion — Azure (internet mode only)
# =============================================================================
# Required only when DEPLOYMENT_MODE="internet"
# Register an app in Azure AD: https://portal.azure.com
# AZURE_CLIENT_ID=""
# AZURE_CLIENT_SECRET=""
# AZURE_TENANT_ID=""

# =============================================================================
# Internal service addresses (managed by Docker Compose — do NOT set here)
# =============================================================================
# The following are hardcoded in docker-compose.yml for the Docker network:
#   REDIS_URL, NEXT_PUBLIC_API_URL, NEXTAUTH_URL, FASTAPI_UPSTREAM
# Qdrant and embedding settings use the GIDEON_ prefix (see sections above).
# GIDEON_DB_URL is set above and passed through by Docker Compose.

